---
import Layout from "../layouts/Layout.astro";

const articles = [
  {
    title: "How to fix your entire life in 1 day",
    url: "https://x.com/thedankoe/status/2010751592346030461",
    source: "Dan Koe",
  },
  {
    title: "Maker's Schedule, Manager's Schedule",
    url: "https://paulgraham.com/makersschedule.html",
    source: "Paul Graham",
  },
  {
    title: "How to Do Great Work",
    url: "https://paulgraham.com/greatwork.html",
    source: "Paul Graham",
  },
  {
    title: "Advice",
    url: "https://patrickcollison.com/advice",
    source: "Patrick Collison",
  },
  {
    title: "Fast",
    url: "https://patrickcollison.com/fast",
    source: "Patrick Collison",
  },
];

const books = [
  { title: "Anathem", author: "Neal Stephenson" },
  { title: "Steve Jobs", author: "Walter Isaacson" },
  { title: "Elon Musk", author: "Walter Isaacson" },
  { title: "Made in Japan", author: "Akio Morita" },
  { title: "Boyd", author: "Robert Coram" },
  { title: "1984", author: "George Orwell" },
  { title: "The Prince", author: "Machiavelli" },
  { title: "Meditations", author: "Marcus Aurelius" },
  { title: "The Design of Everyday Things", author: "Donald A. Norman" },
  { title: "Bobby Fischer Teaches Chess", author: "Bobby Fischer" },
  { title: "The Goal", author: "Eliyahu M. Goldratt" },
  { title: "Zero to One", author: "Peter Thiel" },
  { title: "Range", author: "David Epstein" },
];
---

<Layout title="Reading list | Nicholas Charriere">
  <h1 class="text-4xl mb-6 font-bold text-heading">Reading list</h1>
  <p class="mb-8">
    I read mostly fiction — I love the classics, fantasy, and sci-fi. But I'm listing books here that fall outside those categories, since that's the more interesting projection for this blog.
  </p>

  <h2 class="text-2xl font-bold text-heading mb-4">Books</h2>
  <ul class="list-disc pl-5 mb-12">
    {
      books.map((book) => (
        <li class="mb-1">
          <strong class="text-heading">{book.title}</strong> — {book.author}
        </li>
      ))
    }
  </ul>

  <h2 class="text-2xl font-bold text-heading mb-4">Articles</h2>
  <ul class="list-disc pl-5 mb-12">
    {
      articles.map((article) => (
        <li class="mb-1">
          <a
            href={article.url}
            class="text-link hover:underline"
            target="_blank"
            rel="noopener noreferrer"
          ><strong>{article.title}</strong></a> — {article.source}
        </li>
      ))
    }
  </ul>
</Layout>
