---
import { ViewTransitions } from "astro:transitions";
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, image } = Astro.props || { title: "Nicholas Charriere" };
const { description } = Astro.props || {
  description: "The personal website of Nicholas Charriere.",
};
const ogImage = image || "https://nicholascharriere.com/nicholas2.jpg";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <meta
      name="keywords"
      content="Nicholas Charriere,Srcbook,founder,personal page nicholas charriere,programmer AI"
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://nicholascharriere.com/" />
    <meta property="og:site_name" content="Nicholas Charriere" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@nichochar" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content={ogImage}
    /><link rel="icon" href="/favicon.ico" type="image/x-icon" sizes="any" />
    <meta name="next-size-adjust" />
    <meta name="generator" content={Astro.generator} />
    <script
      is:inline
      defer
      data-domain="nicholascharriere.com"
      src="https://plausible.io/js/script.js"></script>
    <title>{title}</title>

    <ViewTransitions />
  </head>
  <body class="bg-white text-body max-w-[760px] mx-auto p-5 leading-normal">
    <header>
      <a href="/" class="no-underline hover:no-underline">
        <h1 class="text-[1.5em] text-heading font-bold">Nicholas Charriere</h1>
      </a>
      <nav class="flex flex-row flex-wrap gap-x-3 my-4">
        <a href="/blog" class="text-link hover:underline">Blog</a>
        <a href="/projects" class="text-link hover:underline">Projects</a>
        <a href="/reading" class="text-link hover:underline">Reading</a>
        <a href="/watching" class="text-link hover:underline">Watching</a>
        <a href="/quotes" class="text-link hover:underline">Quotes</a>
        <a href="https://x.com/nichochar" class="text-link hover:underline" target="_blank">@nichochar</a>
      </nav>
    </header>

    <main class="leading-relaxed mt-8">
      <slot />
    </main>
  </body>
</html>
